# Sample CI for consumer repos with genetic-ai-starter submodule
name: genetic-ai-validate

on:
  push:
    branches: [main]
  pull_request:

jobs:
  kit-health:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
        with:
          submodules: recursive
      - uses: actions/setup-node@v4
        with:
          node-version: '20'
      - name: ci-kit
        run: node tools/genetic-ai-starter/scripts/ci-kit.mjs --target .
      - name: Upload upgrade report on failure
        if: failure()
        uses: actions/upload-artifact@v4
        with:
          name: genetic-ai-upgrade-report
          path: .genetic-ai/last-upgrade-report.json
          if-no-files-found: ignore
