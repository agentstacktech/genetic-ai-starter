# Sample consumer CI — rename to genetic-ai-validate.yml and adjust kit path
name: genetic-ai-validate

on:
  pull_request:
    paths:
      - 'docs/ai/**'
      - 'philosophy/**'
      - '**/AI_INDEX.md'
      - '.cursor/**'
      - 'tools/genetic-ai-starter/**'
      - '.genetic-ai/**'

jobs:
  validate:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
        with:
          submodules: recursive
      - uses: actions/setup-node@v4
        with:
          node-version: '20'
      - name: genetic-ai kit CI
        run: node tools/genetic-ai-starter/scripts/ci-kit.mjs --target .
      - name: submodule drift (optional)
        run: node tools/genetic-ai-starter/scripts/check-submodule-drift.mjs --target .
        continue-on-error: true
